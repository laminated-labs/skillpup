{
  "name": "skillpup",
  "version": "0.1.1",
  "description": "CLI for storing and fetching agent skills from a private git-backed registry.",
  "main": "dist/cli.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laminated-labs/skillpup.git"
  },
  "homepage": "https://github.com/laminated-labs/skillpup#readme",
  "bugs": {
    "url": "https://github.com/laminated-labs/skillpup/issues"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "pretest": "pnpm run build",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.30.3",
  "bin": {
    "skillpup": "./dist/cli.js"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "execa": "^9.6.1",
    "ora": "^9.3.0",
    "semver": "^7.7.4",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
