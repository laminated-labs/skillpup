# Codex allowlist for skillpup.

prefix_rule(
    pattern = ["rg"],
    decision = "allow",
    justification = "Repo search is safe.",
)

prefix_rule(
    pattern = ["ls"],
    decision = "allow",
    justification = "List files.",
)

prefix_rule(
    pattern = ["pwd"],
    decision = "allow",
    justification = "Show working directory.",
)

prefix_rule(
    pattern = ["find"],
    decision = "allow",
    justification = "Inspect the repository tree.",
)

prefix_rule(
    pattern = ["sed"],
    decision = "allow",
    justification = "Read file excerpts.",
)

prefix_rule(
    pattern = ["cat"],
    decision = "allow",
    justification = "Read files.",
)

prefix_rule(
    pattern = ["jq"],
    decision = "allow",
    justification = "Inspect JSON files and command output.",
)

prefix_rule(
    pattern = ["git", ["status", "diff", "log", "branch", "rev-parse", "ls-files", "show"]],
    decision = "allow",
    justification = "Read-only git inspection.",
)

prefix_rule(
    pattern = ["pnpm", ["install", "i", "build", "test", "exec", "dlx", "run"]],
    decision = "allow",
    justification = "Node package workflows for this repo.",
)

prefix_rule(
    pattern = ["just", ["install", "build", "test", "skills", "docs", "context"]],
    decision = "allow",
    justification = "Repo task runners.",
)

prefix_rule(
    pattern = ["node"],
    decision = "allow",
    justification = "Local Node-based inspection and repo tooling.",
)

prefix_rule(
    pattern = ["gh", "auth", "status"],
    decision = "allow",
    justification = "Read GitHub CLI authentication status for repo workflows.",
)

prefix_rule(
    pattern = ["gh", "repo", "view"],
    decision = "allow",
    justification = "Inspect repository metadata from GitHub.",
)

prefix_rule(
    pattern = ["gh", "pr", ["list", "view"]],
    decision = "allow",
    justification = "Read pull request metadata and review state from GitHub.",
)

prefix_rule(
    pattern = ["gh", "api", "graphql"],
    decision = "prompt",
    justification = "GraphQL access is useful, but each invocation should still be reviewed because the prefix also covers mutations.",
    match = [
        "gh api graphql -f query='query { viewer { login } }'",
        "gh api graphql -f query='mutation { closeIssue(input:{issueId:\"x\"}) { issue { id } } }'",
    ],
    not_match = [
        "gh api repos/openai/codex/pulls",
    ],
)

prefix_rule(
    pattern = ["python", "/workspaces/infrastructure/.agents/skills/gh-address-comments/scripts/fetch_comments.py"],
    decision = "allow",
    justification = "Repo-local skill fetches PR review comments for the current branch.",
)

# Allow both "python" and "python3" for the fetch_comments.py script to accommodate different environments.
prefix_rule(
    pattern = ["python3", "/workspaces/infrastructure/.agents/skills/gh-address-comments/scripts/fetch_comments.py"],
    decision = "allow",
    justification = "Repo-local skill fetches PR review comments for the current branch.",
)
